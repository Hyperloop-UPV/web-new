---
import "../styles/global.css";
import i18next from "i18next";
import { HeadHrefLangs } from "astro-i18next/components";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  img?: string;
  image?: string;
}

const {
  title = "Hyperloop UPV",
  description = "Hyperloop UPV designs and validates high-speed transportation systems through real engineering and testing.",
  img,
  image,
} = Astro.props as Props;

const socialImage = img ?? image ?? "/img/pod_full.jpeg";
const socialImageUrl = socialImage.startsWith("http")
  ? socialImage
  : new URL(socialImage, Astro.url).href;
---

<!doctype html>
<html lang={i18next.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/img/isotype_white.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title + " | Hyperloop UPV"}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title + " | Hyperloop UPV"} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title + " | Hyperloop UPV"} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <HeadHrefLangs />
    <ClientRouter />
  </head>
  <body class="m-0 w-full h-full font-sans bg-[#0f0f0f] text-white">
    <div
      id="page-transition-overlay"
      class="page-transition-overlay"
      aria-hidden="true"
    >
      <img
        src="/img/isotype_white.svg"
        alt=""
        class="page-transition-logo"
        draggable="false"
      />
    </div>

    <div id="app-cursor" aria-hidden="true" class="app-cursor hidden">
      <div class="app-cursor-dot"></div>
      <div class="app-cursor-ring"></div>
    </div>

    <slot name="header" />
    <div id="smooth-wrapper" class="relative overflow-auto w-full h-full">
      <div id="smooth-content">
        <slot />
      </div>
    </div>

    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { Observer } from "gsap/all";

      gsap.registerPlugin(ScrollTrigger, Observer);

      document.addEventListener("astro:before-preparation", () => {
        ScrollTrigger.getAll().forEach((t) => t.kill());
        Observer.getAll().forEach((o) => o.kill());
        const smoother = (window as any).homeScrollSmoother;
        if (smoother && typeof smoother.kill === "function") {
          smoother.kill();
          (window as any).homeScrollSmoother = null;
        }
      });

      (() => {
        const root = document.documentElement;
        let transitionCleanup: number | undefined;

        const clearTransitionClasses = () => {
          root.classList.remove(
            "is-page-transitioning",
            "is-page-transition-leaving",
          );
        };

        const startPageTransition = () => {
          if (transitionCleanup) {
            window.clearTimeout(transitionCleanup);
          }
          root.classList.remove("is-page-transition-leaving");
          root.classList.add("is-page-transitioning");
        };

        const endPageTransition = () => {
          root.classList.add("is-page-transition-leaving");
          transitionCleanup = window.setTimeout(() => {
            clearTransitionClasses();
          }, 650);
        };

        document.addEventListener("astro:before-preparation", () => {
          startPageTransition();
        });

        document.addEventListener("astro:after-swap", () => {
          endPageTransition();
        });

        document.addEventListener("astro:page-load", () => {
          if (root.classList.contains("is-page-transitioning")) {
            endPageTransition();
          } else {
            clearTransitionClasses();
          }
        });
      })();

      const initCursor = () => {
        const cursor = document.getElementById("app-cursor");
        if (!cursor || !window.matchMedia("(pointer: fine)").matches) {
          if (cursor) cursor.remove();
          return () => {};
        }
        const dot = cursor.querySelector(".app-cursor-dot");
        const ring = cursor.querySelector(".app-cursor-ring");
        if (!dot || !ring) {
          cursor.remove();
          return () => {};
        }

        document.documentElement.classList.add("has-custom-cursor");
        cursor.classList.remove("hidden");

        const move = (x: number, y: number) => {
          cursor.style.transform = `translate3d(${x}px, ${y}px, 0)`;
        };

        let stretch = 0;
        let stretchTarget = 0;
        let shift = 0;
        let shiftTarget = 0;
        let morphRaf = 0;

        const animateMorph = () => {
          stretchTarget *= 0.84;
          shiftTarget *= 0.82;

          stretch += (stretchTarget - stretch) * 0.22;
          shift += (shiftTarget - shift) * 0.2;

          cursor.style.setProperty("--cursor-stretch", stretch.toFixed(3));
          cursor.style.setProperty("--cursor-shift", `${shift.toFixed(2)}px`);

          const active =
            Math.abs(stretch) > 0.01 ||
            Math.abs(stretchTarget) > 0.01 ||
            Math.abs(shift) > 0.1 ||
            Math.abs(shiftTarget) > 0.1;

          if (active) {
            morphRaf = window.requestAnimationFrame(animateMorph);
          } else {
            stretch = 0;
            stretchTarget = 0;
            shift = 0;
            shiftTarget = 0;
            cursor.style.setProperty("--cursor-stretch", "0");
            cursor.style.setProperty("--cursor-shift", "0px");
            morphRaf = 0;
          }
        };

        const kickMorph = (deltaY: number) => {
          const amount = Math.min(Math.abs(deltaY) / 240, 1);
          stretchTarget = Math.min(1, stretchTarget + amount * 0.9);
          shiftTarget = Math.max(
            -8,
            Math.min(
              8,
              shiftTarget + Math.sign(deltaY || 1) * (1.6 + amount * 4.2),
            ),
          );

          if (!morphRaf) {
            morphRaf = window.requestAnimationFrame(animateMorph);
          }
        };

        const isInteractive = (target: EventTarget | null) => {
          if (!(target instanceof Element)) return false;
          return !!target.closest(
            'a, button, [role="button"], input[type="button"], input[type="submit"], summary',
          );
        };

        const onMouseMove = (e: MouseEvent) => {
          move(e.clientX, e.clientY);
        };

        const onWheel = (e: WheelEvent) => {
          kickMorph(e.deltaY);
        };

        const onMouseOver = (e: MouseEvent) => {
          if (isInteractive(e.target)) {
            cursor.classList.add("is-link");
          }
        };

        const onMouseOut = (e: MouseEvent) => {
          if (isInteractive(e.target)) {
            cursor.classList.remove("is-link");
          }
        };

        const onMouseDown = () => {
          cursor.classList.add("is-down");
        };

        const onMouseUp = () => {
          cursor.classList.remove("is-down");
        };

        const onMouseLeave = () => {
          cursor.classList.add("is-hidden");
        };

        const onMouseEnter = () => {
          cursor.classList.remove("is-hidden");
        };

        document.addEventListener("mousemove", onMouseMove);
        document.addEventListener("wheel", onWheel, { passive: true });
        document.addEventListener("mouseover", onMouseOver);
        document.addEventListener("mouseout", onMouseOut);
        document.addEventListener("mousedown", onMouseDown);
        document.addEventListener("mouseup", onMouseUp);
        document.addEventListener("mouseleave", onMouseLeave);
        document.addEventListener("mouseenter", onMouseEnter);

        return () => {
          if (morphRaf) cancelAnimationFrame(morphRaf);
          document.removeEventListener("mousemove", onMouseMove);
          document.removeEventListener("wheel", onWheel);
          document.removeEventListener("mouseover", onMouseOver);
          document.removeEventListener("mouseout", onMouseOut);
          document.removeEventListener("mousedown", onMouseDown);
          document.removeEventListener("mouseup", onMouseUp);
          document.removeEventListener("mouseleave", onMouseLeave);
          document.removeEventListener("mouseenter", onMouseEnter);
        };
      };

      if ((window as any).__cursorCleanup) {
        (window as any).__cursorCleanup();
      }
      (window as any).__cursorCleanup = initCursor();
    </script>
  </body>
</html>
