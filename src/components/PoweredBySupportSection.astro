---
import Title from "./Title.astro";
import Button from "./Button.astro";

interface Props {
  logos?: string[];
}

const { logos = [] } = Astro.props as Props;

const logoSource = logos;

const logoRows = [
  {
    duration: 30,
    direction: "left" as const,
    logos: logoSource,
  },
  {
    duration: 34,
    direction: "right" as const,
    logos: [...logoSource].reverse(),
  },
  {
    duration: 28,
    direction: "left" as const,
    logos: logoSource,
  },
  {
    duration: 32,
    direction: "right" as const,
    logos: [...logoSource].reverse(),
  },
];

const logosPerTrack = Array.from({ length: 18 });
---

<section
  class="parallax-section relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-8 py-16 text-white bg-[#ff7f24]"
>
  <div
    class="js-parallax-layer absolute inset-0 z-10 grid grid-rows-4 gap-[clamp(1.1rem,1.9vw,1.8rem)] px-0 py-[clamp(1.5rem,3vw,2.75rem)] pointer-events-none will-change-transform opacity-60"
    data-depth="14"
    aria-hidden="true"
  >
    {
      logoRows.map((row, rowIndex) => (
        <div
          class="marquee-row-mask flex h-[clamp(5rem,8vw,7rem)] items-center overflow-hidden"
          style={`--row-duration:${row.duration}s; --row-delay:${rowIndex * -2.4}s;`}
        >
          <div
            class:list={[
              "flex min-w-max items-center gap-3",
              row.direction === "left"
                ? "animate-marquee-left motion-reduce:[animation-duration:0.01ms] motion-reduce:[animation-iteration-count:1]"
                : "animate-marquee-right motion-reduce:[animation-duration:0.01ms] motion-reduce:[animation-iteration-count:1]",
            ]}
          >
            {logosPerTrack.map((_, index) => {
              const logoSrc = row.logos[index % row.logos.length];
              return (
                <div class="flex h-full min-w-[clamp(10rem,15vw,14rem)] items-center justify-center px-2">
                  <img
                    src={logoSrc}
                    alt="Partner logo"
                    loading="lazy"
                    decoding="async"
                    class="max-h-full h-[clamp(2rem,4vw,3.5rem)] max-w-[clamp(9rem,13vw,12rem)] w-auto object-contain opacity-92 drop-shadow-[0_4px_12px_rgba(0,0,0,0.35)]"
                  />
                </div>
              );
            })}
          </div>
          <div
            class:list={[
              "flex min-w-max items-center gap-[clamp(0.65rem,1.4vw,1.4rem)]",
              row.direction === "left"
                ? "animate-marquee-left motion-reduce:[animation-duration:0.01ms] motion-reduce:[animation-iteration-count:1]"
                : "animate-marquee-right motion-reduce:[animation-duration:0.01ms] motion-reduce:[animation-iteration-count:1]",
            ]}
            aria-hidden="true"
          >
            {logosPerTrack.map((_, index) => {
              const logoSrc = row.logos[index % row.logos.length];
              return (
                <div class="flex h-[clamp(5rem,8vw,7rem)] min-w-[clamp(10rem,15vw,14rem)] items-center justify-center rounded-[0.95rem] px-2 max-md:h-[4rem]">
                  <img
                    src={logoSrc}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    class="max-h-full h-[clamp(2rem,4vw,3.5rem)] max-w-[clamp(9rem,13vw,12rem)] w-auto object-contain opacity-92 drop-shadow-[0_4px_12px_rgba(0,0,0,0.35)]"
                  />
                </div>
              );
            })}
          </div>
        </div>
      ))
    }
  </div>

  <div
    class="relative z-20 flex max-w-[min(92vw,780px)] flex-col gap-[18px] text-left items-start"
  >
    <Title
      text="Powered by your support"
      class="m-0 text-[clamp(2rem,6.2vw,4rem)] leading-[0.95] font-black tracking-[-0.03em] text-balance"
    />
    <Title
      tag="p"
      text="We are powered by our sponsors and partners, if you want to help make this project a reality, consider supporting us!"
      class="text-base leading-relaxed text-white/72 md:text-lg"
    />
    <div class="flex justify-center">
      <Button variant="primary">Support Us</Button>
    </div>
  </div>
</section>
