---
import i18next, { t } from "i18next";
import { localizePath } from "astro-i18next";
import {
  getNextLocale,
  getLocaleLabel,
  SUPPORTED_LOCALES,
  stripLocale,
} from "../lib/i18n";

const navItems = [
  { label: t("nav.about"), href: localizePath("/about") },
  { label: t("nav.team"), href: localizePath("/team") },
  { label: t("nav.trajectory"), href: localizePath("/trajectory") },
  { label: t("nav.investigation"), href: localizePath("/investigation") },
  { label: t("nav.partners"), href: localizePath("/partners") },
  { label: t("nav.contact"), href: localizePath("/contact") },
];

// Language menu data
const languageImageMap = {
  en: "/img/en.png",
  es: "/img/es.png",
  va: "/img/va.png",
};

const currentLocale = i18next.language || "en";
const nextLocale = getNextLocale(currentLocale);
const currentLocaleLabel = getLocaleLabel(currentLocale);
const currentLocaleImage = languageImageMap[currentLocale];

// Get current page path without locale prefix
const currentPath = stripLocale(Astro.url.pathname);

const languageOptions = SUPPORTED_LOCALES.map((locale) => ({
  label: getLocaleLabel(locale),
  href: localizePath(currentPath, locale),
  isActive: currentLocale === locale,
  image: languageImageMap[locale],
}));

const homeHref = localizePath("/");
---

<header
  class="lg:mt-3 lg:mx-3 rounded-b-3xl lg:rounded-full top-0 left-0 w-full max-w-[1500px] left-1/2 -translate-x-1/2 z-[1000] flex items-center justify-between px-8 py-4 bg-[rgba(10,10,10,0.85)] backdrop-blur-xl lg:border border-white/[0.06] fixed"
>
  <a
    href={homeHref}
    class="no-underline text-white text-xl tracking-tight flex items-center gap-3 z-10"
  >
    <img
      src="/img/isotype_white.svg"
      alt="Logo"
      class="logo-light block h-8"
    /><img
      src="/img/isotype_text.svg"
      alt="Logo"
      class="logo-bold h-4 hidden lg:block"
    />
  </a>

  <nav class="hidden md:flex items-center gap-8">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="text-sm text-white/60 hover:text-white transition-colors duration-200 no-underline uppercase tracking-widest"
        >
          {item.label}
        </a>
      ))
    }
    <span class="flex flex-row items-center gap-3">
      <div class="relative group hidden md:block">
        <button
          id="lang-switcher"
          class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest translate-x-3 text-white/60 hover:text-white transition-colors duration-200 no-underline border border-white/20 rounded-full px-6 py-3"
          aria-label="Switch language"
          aria-expanded="false"
        >
          <img
            src={currentLocaleImage}
            alt={currentLocaleLabel}
            class="w-5 h-4 object-cover rounded"
          />
          {currentLocaleLabel}
        </button>
        <div
          id="lang-dropdown"
          class="absolute right-0 mt-2 w-32 bg-[rgba(10,10,10,0.95)] border border-white/20 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
        >
          {
            languageOptions.map((option) => (
              <a
                href={option.href}
                class={`flex items-center gap-2 w-full px-4 py-3 text-xs font-semibold uppercase tracking-widest transition-colors border-b border-white/10 last:border-b-0 ${
                  option.isActive
                    ? "text-white bg-white/10"
                    : "text-white/60 hover:text-white hover:bg-white/5"
                }`}
              >
                <img
                  src={option.image}
                  alt={option.label}
                  class="w-5 h-4 object-cover rounded"
                />
                {option.label}
              </a>
            ))
          }
        </div>
      </div>

      <a
        href={localizePath("/join")}
        class="hidden md:inline-flex text-xs font-semibold uppercase tracking-widest translate-x-3 text-black bg-white hover:bg-white/90 transition-colors duration-200 no-underline border border-white/20 rounded-full px-6 py-3"
        aria-label="Switch language"
      >
        {t("header.join_us")}
      </a>
    </span>
  </nav>

  <button
    id="menu-toggle"
    class="md:hidden relative z-10 flex flex-col justify-center items-center w-10 h-10 gap-1.5 bg-transparent border-none cursor-pointer"
    aria-label="Toggle menu"
    aria-expanded="false"
  >
    <span
      class="menu-bar block w-6 h-px bg-white transition-all duration-300 origin-center"
    ></span>
    <span
      class="menu-bar block w-6 h-px bg-white transition-all duration-300 origin-center"
    ></span>
    <span
      class="menu-bar block w-6 h-px bg-white transition-all duration-300 origin-center"
    ></span>
  </button>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-[999] flex flex-col items-center justify-center bg-[#050505]/95 backdrop-blur-2xl opacity-0 pointer-events-none transition-opacity duration-300"
>
  <nav class="flex flex-col items-center gap-8">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link text-2xl font-semibold text-white/70 hover:text-white no-underline uppercase tracking-widest transition-colors duration-200"
        >
          {item.label}
        </a>
      ))
    }
    <a
      href={localizePath("/join")}
      class="mobile-nav-link text-2xl font-semibold bg-white px-4 py-2 rounded-full text-black hover:bg-white/90 no-underline uppercase tracking-widest transition-colors duration-200"
    >
      {t("header.join_us")}
    </a>
    <div class="flex gap-3 mt-4 pt-4 border-t border-white/20">
      {
        languageOptions.map((option) => (
          <a
            href={option.href}
            class={`flex items-center gap-2 text-sm font-semibold uppercase tracking-widest px-3 py-2 rounded-full transition-colors ${
              option.isActive
                ? "text-white bg-white/10 border border-white/20"
                : "text-white/60 hover:text-white border border-white/10"
            }`}
          >
            <img
              src={option.image}
              alt={option.label}
              class="w-5 h-4 object-cover rounded"
            />
            {option.label}
          </a>
        ))
      }
    </div>
  </nav>
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if ((window as any).__headerInitialized) {
    // Already initialized on a previous page; global cleanup handled by Layout
  } else {
    (window as any).__headerInitialized = true;

    document.addEventListener("astro:before-preparation", () => {
      (window as any).__headerInitialized = false;
    }, { once: true });
  }

  const isotypeText = document.querySelector(".logo-bold");
  if (isotypeText) {
    gsap.to(isotypeText, {
      x: -18,
      opacity: 0,
      ease: "none",
      scrollTrigger: {
        start: 0,
        end: 200,
        scrub: true,
      },
    });
  }

  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
  const bars = toggle.querySelectorAll(".menu-bar");
  const links = menu.querySelectorAll(".mobile-nav-link");
  let isOpen = false;

  function openMenu() {
    isOpen = true;
    toggle.setAttribute("aria-expanded", "true");
    menu.classList.remove("opacity-0", "pointer-events-none");
    menu.classList.add("opacity-100", "pointer-events-auto");
    document.body.style.overflow = "hidden";
    gsap.to(bars[0], { rotate: 45, y: 5, duration: 0.3 });
    gsap.to(bars[1], { opacity: 0, duration: 0.2 });
    gsap.to(bars[2], { rotate: -45, y: -7, duration: 0.3 });
    gsap.from(links, {
      y: 30,
      opacity: 0,
      duration: 0.4,
      stagger: 0.06,
      ease: "power3.out",
      delay: 0.1,
    });
  }

  function closeMenu() {
    isOpen = false;
    toggle.setAttribute("aria-expanded", "false");
    menu.classList.add("opacity-0", "pointer-events-none");
    menu.classList.remove("opacity-100", "pointer-events-auto");
    document.body.style.overflow = "";
    gsap.to(bars[0], { rotate: 0, y: 0, duration: 0.3 });
    gsap.to(bars[1], { opacity: 1, duration: 0.2 });
    gsap.to(bars[2], { rotate: 0, y: 0, duration: 0.3 });
  }

  toggle.addEventListener("click", () => (isOpen ? closeMenu() : openMenu()));
  links.forEach((link) => link.addEventListener("click", closeMenu));
  }
</script>
