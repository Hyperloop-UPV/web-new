---
import Button from "./Button.astro";
import { t } from "i18next";

interface Props {
  jobOpening: any;
  key?: string;
  [prop: string]: any;
}

const { jobOpening } = Astro.props as Props;
---

<article
  class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-sm backdrop-blur-sm"
>
  <header
    class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4"
  >
    <div>
      <h3 class="text-xl font-semibold text-white">{jobOpening.title}</h3>
      {
        jobOpening.shortDescription && (
          <p class="mt-2 text-white/70">{jobOpening.shortDescription}</p>
        )
      }
    </div>
    <div class="flex items-center gap-3">
      {
        jobOpening.subgroup?.name && (
          <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white">
            {jobOpening.subgroup.name}
          </span>
        )
      }
      {
        jobOpening.formLink && (
          <Button variant="outline" href={jobOpening.formLink} class="min-w-40">
            {t("join.apply")}
          </Button>
        )
      }
    </div>
  </header>

  {
    jobOpening.fullDescription && (
      <div
        class="mt-5 text-white/70 prose prose-invert max-w-none"
        set:html={jobOpening.fullDescription}
      />
    )
  }
</article>
