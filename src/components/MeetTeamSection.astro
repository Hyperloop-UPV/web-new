---
import Button from "./Button.astro";
import Title from "./Title.astro";
import { t } from "i18next";

interface TeamMemberCard {
  image: string;
  name: string;
  role?: string;
}

interface Props {
  teamMembers?: TeamMemberCard[];
}

const { teamMembers = [] } = Astro.props as Props;
---

<section
  class="pin-section relative bg-[#0f0f0f] text-white py-20 px-6 md:px-10"
>
  <div
    class="mx-auto max-w-6xl grid md:grid-cols-[minmax(260px,320px)_1fr] gap-10 md:gap-14 items-start"
  >
    <div class="team-pin-column md:self-start">
      <div class="team-pin-text flex flex-col gap-4 md:pt-28">
        <Title
          text={t("team.title")}
          class="m-0 text-[clamp(1.8rem,3vw,3rem)] font-black leading-[1.05]"
        />
        <Title
          text={t("team.subtitle")}
          class="text-lg text-white/70 leading-relaxed"
        />
        <div class="pt-2">
          <Button variant="outline" href="/join">{t("team.cta")}</Button>
        </div>
      </div>
    </div>

    <div class="team-grid relative min-h-[180vh]">
      <div
        class="grid auto-rows-[150px] sm:auto-rows-[190px] grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4"
      >
        {
          teamMembers.map((member, idx) => (
            <figure class="team-card group relative overflow-hidden rounded-2xl">
              <img
                src={member.image}
                alt={`${member.name} portrait`}
                loading="lazy"
                decoding="async"
                class="team-face-image h-full w-full object-contain transition-transform duration-700 ease-out group-hover:scale-110"
              />
              <figcaption class="team-face-bubble" aria-hidden="true">
                <span class="team-face-name">{member.name}</span>
                <span class="team-face-role">
                  {member.role ?? t("team.roleFallback")}
                </span>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .team-face-image {
    position: relative;
    z-index: 1;
    mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
  }

  .team-face-bubble {
    position: absolute;
    bottom: 0.65rem;
    right: 0.65rem;
    display: inline-flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.5rem 0.65rem;
    max-width: calc(100% - 1.3rem);
    border-radius: 0.8rem;
    background: rgba(8, 8, 8);
    border: 1px solid rgba(255, 255, 255, 0.2);
    z-index: 3;
    opacity: 0;
    transform: translateY(10px) scale(0.96);
    transform-origin: top left;
    transition:
      opacity 260ms ease,
      transform 260ms ease;
    pointer-events: none;
  }

  .team-face-bubble::after {
    content: "";
    position: absolute;
    left: 3rem;
    top: -0.28rem;
    width: 0.5rem;
    height: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    border-right: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(8, 8, 8);
    transform: rotate(-45deg);
  }

  .team-face-name {
    font-weight: 700;
    font-size: 0.82rem;
    line-height: 1.1;
    color: rgba(255, 255, 255, 0.98);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .team-face-role {
    font-weight: 300;
    font-size: 0.72rem;
    line-height: 1.1;
    color: rgba(255, 255, 255, 0.76);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .team-card:hover .team-face-bubble,
  .team-card:focus-within .team-face-bubble {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>
