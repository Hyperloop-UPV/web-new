---
interface Props {
	primaryImage: string;
	secondaryImage: string;
	class?: string;
}

const { primaryImage, secondaryImage, class: className = '' } = Astro.props;
---

<div
	class:list={['blob-reveal relative w-full h-full overflow-hidden', className]}
	data-primary={primaryImage}
	data-secondary={secondaryImage}
>
	<canvas class="blob-canvas absolute inset-0 w-full h-full"></canvas>
</div>

<script>
	import { gsap } from 'gsap';

	// ---------- WebGL blob-reveal with viscous mouse tracking ----------

	const VERTEX = `
		attribute vec2 a_position;
		varying vec2 v_uv;
		void main() {
			v_uv = a_position * 0.5 + 0.5;
			v_uv.y = 1.0 - v_uv.y;
			gl_Position = vec4(a_position, 0.0, 1.0);
		}
	`;

	const FRAGMENT = `
		precision highp float;

		uniform sampler2D u_primary;
		uniform sampler2D u_secondary;
		uniform vec2  u_mouse;
		uniform vec2  u_resolution;
		uniform float u_radius;
		uniform float u_time;

		varying vec2 v_uv;

		float hash(vec2 p) {
			return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
		}
		float noise(vec2 p) {
			vec2 i = floor(p); vec2 f = fract(p);
			f = f * f * (3.0 - 2.0 * f);
			float a = hash(i); float b = hash(i + vec2(1.0,0.0));
			float c = hash(i + vec2(0.0,1.0)); float d = hash(i + vec2(1.0,1.0));
			return mix(mix(a,b,f.x), mix(c,d,f.x), f.y);
		}

		void main() {
			vec2 uv = v_uv;
			float aspect = u_resolution.x / u_resolution.y;
			vec2 coord = uv; coord.x *= aspect;
			vec2 mouse = u_mouse; mouse.x *= aspect;

			// Distance with multi-octave organic deformation
			float dist = length(coord - mouse);
			vec2 animUV = coord * 3.5 + u_time * 0.25;
			float wobble  = noise(animUV) * 0.10;
			      wobble += noise(animUV * 2.1 + 1.7) * 0.05;
			      wobble += noise(animUV * 4.3 + 3.1) * 0.025;
			dist += wobble;

			// Sharp mask
			float te = u_radius * 0.008;
			float mask = 1.0 - smoothstep(u_radius - te, u_radius + te, dist);

			// Thin edge slime distortion
			float edgeRing = smoothstep(u_radius - 0.02, u_radius, dist)
			               * (1.0 - smoothstep(u_radius, u_radius + 0.02, dist));
			vec2 dir = normalize(coord - mouse + 0.001);
			vec2 distortedUV = uv + dir * edgeRing * 0.006;

			vec4 colPrimary   = texture2D(u_primary,   distortedUV);
			vec4 colSecondary = texture2D(u_secondary, uv);
			gl_FragColor = mix(colPrimary, colSecondary, mask);
		}
	`;

	function createShader(gl: WebGLRenderingContext, type: number, src: string) {
		const s = gl.createShader(type)!;
		gl.shaderSource(s, src);
		gl.compileShader(s);
		if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
			console.error(gl.getShaderInfoLog(s));
			gl.deleteShader(s);
			return null;
		}
		return s;
	}

	function createProgram(gl: WebGLRenderingContext, vs: WebGLShader, fs: WebGLShader) {
		const p = gl.createProgram()!;
		gl.attachShader(p, vs);
		gl.attachShader(p, fs);
		gl.linkProgram(p);
		if (!gl.getProgramParameter(p, gl.LINK_STATUS)) {
			console.error(gl.getProgramInfoLog(p));
			return null;
		}
		return p;
	}

	function loadTexture(gl: WebGLRenderingContext, url: string): Promise<WebGLTexture> {
		return new Promise((resolve) => {
			const tex = gl.createTexture()!;
			const img = new Image();
			img.crossOrigin = 'anonymous';
			img.onload = () => {
				gl.bindTexture(gl.TEXTURE_2D, tex);
				gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, img);
				gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
				gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
				gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
				gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
				resolve(tex);
			};
			img.src = url;
		});
	}

	// ---- Init each blob-reveal instance ----
	document.querySelectorAll<HTMLElement>('.blob-reveal').forEach(async (container) => {
		if (container.dataset.blobRevealReady === 'true') return;
		container.dataset.blobRevealReady = 'true';

		const canvas = container.querySelector<HTMLCanvasElement>('.blob-canvas')!;
		const gl = canvas.getContext('webgl', { alpha: true, premultipliedAlpha: false });
		if (!gl) return;

		const primarySrc = container.dataset.primary!;
		const secondarySrc = container.dataset.secondary!;

		// Compile shaders
		const vs = createShader(gl, gl.VERTEX_SHADER, VERTEX)!;
		const fs = createShader(gl, gl.FRAGMENT_SHADER, FRAGMENT)!;
		const program = createProgram(gl, vs, fs)!;

		// Full-screen quad
		const buf = gl.createBuffer();
		gl.bindBuffer(gl.ARRAY_BUFFER, buf);
		gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);

		const aPos = gl.getAttribLocation(program, 'a_position');
		gl.enableVertexAttribArray(aPos);
		gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

		// Uniforms
		const uPrimary    = gl.getUniformLocation(program, 'u_primary');
		const uSecondary  = gl.getUniformLocation(program, 'u_secondary');
		const uMouse      = gl.getUniformLocation(program, 'u_mouse');
		const uResolution = gl.getUniformLocation(program, 'u_resolution');
		const uRadius     = gl.getUniformLocation(program, 'u_radius');
		const uTime       = gl.getUniformLocation(program, 'u_time');

		// Load textures
		let [texA, texB] = await Promise.all([
			loadTexture(gl, primarySrc),
			loadTexture(gl, secondarySrc),
		]);

		// Mouse state with viscous interpolation
		const BLOB_RADIUS = 0.30;
		const MAX_R       = 3.0;

		const mouse    = { x: 0.5, y: 0.5 };
		const target   = { x: 0.5, y: 0.5 };
		const velocity = { x: 0, y: 0 };
		const state    = { radius: BLOB_RADIUS };
		let clicking = false;
		let pointerInside = true;
		let rafId = 0;

		function tweenRadius(value: number, duration = 0.35, ease = 'power2.out') {
			gsap.killTweensOf(state, 'radius');
			gsap.to(state, { radius: value, duration, ease });
		}

		const onMouseMove = (e: MouseEvent) => {
			if (clicking) return;
			if (!pointerInside) {
				pointerInside = true;
				tweenRadius(BLOB_RADIUS, 0.4, 'power2.out');
			}
			const rect = canvas.getBoundingClientRect();
			target.x = (e.clientX - rect.left) / rect.width;
			target.y = (e.clientY - rect.top)  / rect.height;
		};

		const onMouseLeave = () => {
			if (clicking) return;
			pointerInside = false;
			tweenRadius(0, 0.35, 'power2.inOut');
			// Keep blob anchored at the last visible position while fading out.
			target.x = mouse.x; target.y = mouse.y;
			velocity.x = 0; velocity.y = 0;
		};

		const onClick = () => {
			if (clicking) return;
			clicking = true;

			// Freeze blob at current smoothed position
			target.x = mouse.x; target.y = mouse.y;
			velocity.x = 0; velocity.y = 0;

			// Phase 1: blob grows outward
			gsap.to(state, {
				radius: MAX_R,
				duration: 0.7,
				ease: 'power2.in',
				onComplete: () => {
					// Background becomes what was inside the blob; blob disappears
					[texA, texB] = [texB, texA];
					state.radius = 0;
					// Phase 2: new blob grows from nothing at the same position
					gsap.to(state, {
						radius: BLOB_RADIUS,
						duration: 0.7,
						ease: 'power2.out',
						onComplete: () => {
							clicking = false;
							if (!pointerInside) {
								tweenRadius(0, 0.2, 'power2.inOut');
							}
						},
					});
				},
			});
		};

		container.addEventListener('mousemove', onMouseMove);
		container.addEventListener('mouseleave', onMouseLeave);
		container.addEventListener('click', onClick);

		// Resize handler
		function resize() {
			const dpr = Math.min(window.devicePixelRatio, 2);
			const w = container.clientWidth;
			const h = container.clientHeight;
			canvas.width  = w * dpr;
			canvas.height = h * dpr;
			gl!.viewport(0, 0, canvas.width, canvas.height);
		}
		const ro = new ResizeObserver(resize);
		ro.observe(container);
		resize();

		// Animation loop
		const DAMPING = 0.06;

		function render(time: number) {
			rafId = requestAnimationFrame(render);
			const t = time * 0.001;

			// Viscous spring-damper
			const dx = target.x - mouse.x;
			const dy = target.y - mouse.y;
			velocity.x += dx * DAMPING; velocity.y += dy * DAMPING;
			velocity.x *= 0.82;         velocity.y *= 0.82;
			mouse.x += velocity.x;      mouse.y += velocity.y;

			gl!.useProgram(program);

			gl!.activeTexture(gl!.TEXTURE0);
			gl!.bindTexture(gl!.TEXTURE_2D, texA);
			gl!.uniform1i(uPrimary, 0);

			gl!.activeTexture(gl!.TEXTURE1);
			gl!.bindTexture(gl!.TEXTURE_2D, texB);
			gl!.uniform1i(uSecondary, 1);

			gl!.uniform2f(uMouse,      mouse.x, mouse.y);
			gl!.uniform2f(uResolution, canvas.width, canvas.height);
			gl!.uniform1f(uRadius,     state.radius);
			gl!.uniform1f(uTime,       t);

			gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
		}

		rafId = requestAnimationFrame(render);

		container.addEventListener('astro:unmount', () => {
			if (rafId) cancelAnimationFrame(rafId);
			ro.disconnect();
			container.removeEventListener('mousemove', onMouseMove);
			container.removeEventListener('mouseleave', onMouseLeave);
			container.removeEventListener('click', onClick);
			gsap.killTweensOf(state, 'radius');
		}, { once: true });
	});
</script>
