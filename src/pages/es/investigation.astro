---
import { changeLanguage, t } from "i18next";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { Leaf, Zap, Armchair } from "lucide-astro";
import { contentRepository } from "../../lib/contentful/repository";

changeLanguage("es");

const pageTitle = String(t("nav.investigation"));
const pageDescription = String(t("investigation.description"));
const investigations = await contentRepository.getInvestigations("en-US");
const homePageContent = await contentRepository.getHomePageContent("en-US");
const latestPodImage = homePageContent.vehicleTimeline[0]?.image ?? "/img/pod.png";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header slot="header" />
  <PageHero
    title={pageTitle}
    description={pageDescription}
    colors={["#ff7f24", "#20274c", "#20274c"]}
  />

  <section
    class="m-auto max-w-6xl flex flex-row items-center justify-between gap-6 bg-[#0f0f0f] px-6 xl:px-0"
  >
    <div class="mt-20 w-full">
      <div class="mb-16">
        <h2 class="text-5xl font-black text-white">
          {t("investigation.why.title")}
        </h2>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-300">
          {t("investigation.why.description")}
        </p>
      </div>

      <div class="flex flex-row items-center justify-between gap-6">
        <div class="text-center">
          <div class="mb-4 flex justify-center">
            <Leaf size={64} class="text-emerald-400" stroke-width={1.5} />
          </div>
          <h3 class="text-xl font-bold text-white">
            {t("investigation.why.sustainability")}
          </h3>
        </div>

        <div class="text-center">
          <div class="mb-4 flex justify-center">
            <Zap size={64} class="text-orange-400" stroke-width={1.5} />
          </div>
          <h3 class="text-xl font-bold text-white">
            {t("investigation.why.speed")}
          </h3>
        </div>

        <div class="text-center">
          <div class="mb-4 flex justify-center">
            <Armchair size={64} class="text-blue-400" stroke-width={1.5} />
          </div>
          <h3 class="text-xl font-bold text-white">
            {t("investigation.why.comfort")}
          </h3>
        </div>
      </div>
    </div>
    <div class="flex items-center">
      <img
        src={latestPodImage}
        alt="Hyperloop Pod"
        class="ml-20 h-[300px] w-full rounded-2xl object-cover"
      />
    </div>
  </section>

  <section class="bg-[#0a0a0a] px-6 py-16 md:px-10 md:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16">
        <h2 class="text-5xl font-black text-white">
          {t("investigation.how.title")}
        </h2>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-300">
          {t("investigation.how.description")}
        </p>
      </div>

      <div class="flex flex-row items-start justify-between gap-20">
        <div class="w-1/3 flex flex-col items-start justify-start gap-4">
          <div>
            <h3 class="text-2xl font-bold text-white">
              {t("investigation.how.vacuum.title")}
            </h3>
            <p class="mt-4 text-slate-300 leading-relaxed">
              {t("investigation.how.vacuum.description")}
            </p>
          </div>
          <img
            src="/img/vacuum_tube.png"
            alt="Vacuum Tube"
            class="rounded-2xl object-cover w-full"
          />
        </div>

        <div class="w-1/3 flex flex-col items-start justify-start gap-4">
          <div>
            <h3 class="text-2xl font-bold text-white">
              {t("investigation.how.capsule.title")}
            </h3>
            <p class="mt-4 text-slate-300 leading-relaxed">
              {t("investigation.how.capsule.description")}
            </p>
          </div>
          <img
            src="/img/pod_capsule.png"
            alt="Pod Capsule"
            class="rounded-2xl object-cover w-full lg:order-1"
          />
        </div>

        <div class="w-1/3 flex flex-col items-start justify-start gap-4">
          <div>
            <h3 class="text-2xl font-bold text-white">
              {t("investigation.how.levitation.title")}
            </h3>
            <p class="mt-4 text-slate-300 leading-relaxed">
              {t("investigation.how.levitation.description")}
            </p>
          </div>
          <img
            src="/img/levitation_system.png"
            alt="Levitation System"
            class="rounded-2xl object-cover w-full"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#0f0f0f] px-6 py-16 md:px-10 md:py-20">
    <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        investigations.map((item) => (
          <article class="rounded-2xl border border-white/10 bg-white/3 overflow-hidden">
            {item.cover && (
              <img
                src={item.cover}
                alt={item.title}
                loading="lazy"
                decoding="async"
                class="h-52 w-full object-cover"
              />
            )}
            <div class="p-5">
              <h2 class="text-xl font-semibold text-white">{item.title}</h2>
              {item.description && (
                <p class="mt-3 text-sm leading-relaxed text-white/70">
                  {item.description}
                </p>
              )}
              {item.document && (
                <a
                  href={item.document}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex text-sm font-semibold uppercase tracking-widest text-white/80 hover:text-white"
                >
                  Open document
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <SiteFooter />
</Layout>
