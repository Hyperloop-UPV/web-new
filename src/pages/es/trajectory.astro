---
import { changeLanguage, t } from "i18next";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import FilterBar from "../../components/FilterBar.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { contentRepository } from "../../lib/contentful/repository";

changeLanguage("es");

const pageTitle = String(t("nav.trajectory"));
const pageDescription = String(t("trajectory.description"));
const homePageContent = await contentRepository.getHomePageContent("en-US");
const vehicles = homePageContent.vehicleTimeline.map((pod) => `${pod.vehicleName} - ${pod.code}`);
---

<Layout title={pageTitle} description={pageDescription}>
  <Header slot="header" />
  <PageHero
    title={pageTitle}
    description={pageDescription}
    colors={["#ff7f24", "#20274c", "#20274c"]}
  />
  <div
    class="w-full max-w-[1100px] mx-auto flex flex-col items-center justify-center relative"
  >
    <div class="py-20 w-full flex flex-row gap-20 items-center justify-between">
      <span class="flex flex-col items-center justify-center gap-1">
        <h1 class="text-5xl font-bold text-center">10+</h1>
        <p class="text-md opacity-60 text-center">Vehículos</p>
      </span>
      <span class="flex flex-col items-center justify-center gap-1">
        <h1 class="text-5xl font-bold text-center">Top 1</h1>
        <p class="text-md opacity-60 text-center">EHW 2024</p>
      </span>
      <span class="flex flex-col items-center justify-center gap-1">
        <h1 class="text-5xl font-bold text-center">5+</h1>
        <p class="text-md opacity-60 text-center">Premios</p>
      </span>
    </div>
    <div class="max-w-[700px] text-center text-2xl py-60">
      <p>
        Cada año desarrollamos desde <span class="text-orange-400 font-bold"
          >cero</span
        > un prototipo completo, aplicando ingeniería, diseño, y fabricación <span
          class="text-orange-400 font-bold">real</span
        >.
      </p>
      <p class="font-bold text-3xl mt-20">Shaping the future.</p>
      <img src="/img/check.png" alt="Check" class="h-16 mx-auto mt-3" />
    </div>
    <nav
      class="sticky top-0 z-30 bg-[#0f0f0f] border-white/10 py-3 px-4 flex gap-2 overflow-x-auto timeline-nav-bar"
    >
      <FilterBar items={vehicles} />
    </nav>
    <div class="vertical-timeline my-12 relative">
      <div
        class="absolute left-1/2 top-0 bottom-0 w-2 bg-white/30 rounded-full timeline-line"
        style="transform: translateX(-50%);"
      >
      </div>
      {
        homePageContent.vehicleTimeline.map((pod, idx) => {
          const isLeft = idx % 2 === 0;
          return (
            <section
              id={`${pod.vehicleName} - ${pod.code}`}
              class="pod-timeline-section mb-24 relative"
              key={pod.code}
            >
              <div class="flex items-stretch justify-between gap-8 relative">
                {isLeft ? (
                  <>
                    <div class="flex-1 flex flex-col justify-center items-end pr-6 text-left">
                      <span class="w-full flex flex-row items-center justify-between gap-3">
                        <h2 class="text-3xl font-bold text-white mb-1">
                          {pod.vehicleName}
                          <p class="text-sm opacity-80 font-medium mb-2">
                            {pod.years}
                          </p>
                        </h2>
                        <h3 class="text-xl font-semibold text-orange-400 px-4 py-2 bg-orange-400/10 rounded-xl mb-2">
                          {pod.code}
                        </h3>
                      </span>
                      <p class="mt-6 mb-2">{pod.description}</p>
                      {pod.accolades.length > 0 && (
                        <ul class="flex flex-wrap gap-2 mt-2">
                          {pod.accolades.map((acc) => (
                            <li class="bg-orange-400/20 text-orange-400 px-2 py-1 rounded text-xs font-semibold">
                              {acc}
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                    <div class="-translate-x-3 flex flex-col items-center w-24 relative">
                      <div class="left-5 w-6 h-6 bg-white rounded-full border-4 border-white/60 mb-2 z-10" />
                      <div class="flex-1" />
                    </div>
                    <div class="flex-1 flex items-center">
                      <img src={pod.image} alt={pod.code} class="h-80 object-contain" />
                    </div>
                  </>
                ) : (
                  <>
                    <div class="flex-1 flex items-center">
                      <img src={pod.image} alt={pod.code} class="h-80 object-contain" />
                    </div>
                    <div class="translate-x-3 flex flex-col items-center w-24 relative">
                      <div class="w-6 h-6 bg-white rounded-full border-4 border-white/60 mb-2 z-10" />
                      <div class="flex-1" />
                    </div>
                    <div class="flex-1 flex flex-col justify-center items-start pl-6 text-left">
                      <span class="w-full flex flex-row items-center justify-between gap-3">
                        <h2 class="text-3xl font-bold text-white mb-1">
                          {pod.vehicleName}
                          <p class="text-sm opacity-80 font-medium mb-2">
                            {pod.years}
                          </p>
                        </h2>
                        <h3 class="text-xl font-semibold text-orange-400 px-4 py-2 bg-orange-400/10 rounded-xl mb-2">
                          {pod.code}
                        </h3>
                      </span>
                      <p class="mt-6 mb-2">{pod.description}</p>
                      {pod.accolades.length > 0 && (
                        <ul class="flex flex-wrap gap-2 mt-2">
                          {pod.accolades.map((acc) => (
                            <li class="bg-orange-400/20 text-orange-400 px-2 py-1 rounded text-xs font-semibold">
                              {acc}
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </>
                )}
              </div>
            </section>
          );
        })
      }
    </div>
  </div>
  <SiteFooter />
</Layout>
