---
import i18next, { changeLanguage } from "i18next";
import { changeLanguage, t } from "i18next";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import MissionImageScatter from "../../components/MissionImageScatter.astro";
import SubsystemsAccordion from "../../components/SubsystemsAccordion.astro";
import VehicleTimeline from "../../components/VehicleTimeline.astro";
import PoweredBySupportSection from "../../components/PoweredBySupportSection.astro";
import MeetTeamSection from "../../components/MeetTeamSection.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { contentRepository } from "../../lib/contentful/repository";

changeLanguage("es");

let contentfulLocale = "en-US";
switch (i18next.language) {
    case "es":
        contentfulLocale = "es";
        break;
    case "en":
        contentfulLocale = "en-US";
        break;
    default:
        contentfulLocale = "en-US";
}
const [homePageContent, members] = await Promise.all([
    contentRepository.getHomePageContent(contentfulLocale),
    contentRepository.getMembers(contentfulLocale),
]);
const { hero, missionImages, subsystemItems, vehicleTimeline, partnerLogos } = homePageContent;
const memberFaces = members
    .filter((member): member is typeof member & {
    image: string;
} => Boolean(member.image))
    .map((member) => ({
    image: member.image,
    name: member.name,
    role: member.role,
}));
const faceGallery = memberFaces.length
    ? Array.from({ length: Math.max(30, memberFaces.length * 3) }, (_, i) => memberFaces[i % memberFaces.length])
    : [];
---

<Layout
  title={t("site.title")}
  description={hero.description ?? t("site.description")}
  img={hero.bg?.[0]}
>
  <Header slot="header" />
  <Hero bg={hero.bg} description={hero.description} />

  <MissionImageScatter
    title={t("mission.title")}
    description={t("mission.description")}
    images={missionImages}
    imageHeight={300}
    class="bg-[#0f0f0f]"
  />

  <SubsystemsAccordion items={subsystemItems} />

  <VehicleTimeline items={vehicleTimeline} />

  <PoweredBySupportSection logos={partnerLogos} />

  <MeetTeamSection teamMembers={faceGallery} />

  <SiteFooter />
</Layout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollSmoother } from "gsap/ScrollSmoother";
  import { Observer } from "gsap/all";

  gsap.registerPlugin(ScrollTrigger, ScrollSmoother, Observer);

  const smoother = ScrollSmoother.create({
    wrapper: "#smooth-wrapper",
    content: "#smooth-content",
    smooth: 1.5,
    effects: true,
    smoothTouch: 0.1,
  });

  let heroLocked = true;
  smoother.paused(true);

  const heroHeight =
    document.querySelector(".hero-section")?.getBoundingClientRect().height ||
    window.innerHeight;

  const heroObserver = Observer.create({
    target: window,
    type: "wheel,touch",
    onDown: () => {
      if (!heroLocked) return;
      heroLocked = false;
      heroObserver.disable();
      smoother.paused(false);
      smoother.scrollTo(heroHeight, true, "top top");
    },
    tolerance: 50,
    preventDefault: true,
  });

  ScrollTrigger.create({
    start: 1,
    end: 2,
    onLeaveBack: () => {
      heroLocked = true;
      smoother.paused(true);
      heroObserver.enable();
    },
  });

  gsap.utils.toArray<HTMLElement>(".fade-up").forEach((el) => {
    gsap.from(el, {
      y: 60,
      opacity: 0,
      duration: 1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: el,
        start: "top 85%",
        toggleActions: "play none none reverse",
      },
    });
  });

  const track = document.querySelector<HTMLElement>(".horizontal-track");
  const panels = gsap.utils.toArray<HTMLElement>(".panel");
  if (track && panels.length) {
    gsap.to(track, {
      x: () => -(track.scrollWidth - window.innerWidth),
      ease: "none",
      scrollTrigger: {
        trigger: ".horizontal-scroll-wrapper",
        pin: true,
        scrub: 1,
        end: () => `+=${track.scrollWidth - window.innerWidth}`,
        invalidateOnRefresh: true,
      },
    });
  }

  const parallaxSection = document.querySelector(".parallax-section");
  const parallaxLayers = gsap.utils.toArray<HTMLElement>(".js-parallax-layer");
  if (parallaxSection && parallaxLayers.length) {
    parallaxLayers.forEach((layer) => {
      const depth = Number(layer.dataset.depth ?? 20);
      gsap.fromTo(
        layer,
        { yPercent: -depth * 0.55 },
        {
          yPercent: depth,
          ease: "none",
          scrollTrigger: {
            trigger: parallaxSection,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
            invalidateOnRefresh: true,
          },
        },
      );
    });
  }
  const teamCopy = document.querySelector(".team-pin-text");
  const teamPinColumn = document.querySelector(".team-pin-column");
  const pinSection = document.querySelector(".pin-section");
  if (teamCopy) {
    gsap.fromTo(
      teamCopy,
      { y: 24, opacity: 0.4 },
      {
        y: 0,
        opacity: 1,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".pin-section",
          start: "top 75%",
          end: "top 40%",
          scrub: true,
        },
      },
    );
  }

  if (
    teamPinColumn &&
    pinSection &&
    window.matchMedia("(min-width: 768px)").matches
  ) {
    ScrollTrigger.create({
      trigger: pinSection,
      start: "top top",
      end: "bottom bottom",
      pin: teamPinColumn,
      pinSpacing: false,
      anticipatePin: 1,
      invalidateOnRefresh: true,
    });
  }

  const teamGrid = document.querySelector(".team-grid");
  if (teamGrid) {
    gsap.fromTo(
      teamGrid,
      { y: 60 },
      {
        y: -140,
        ease: "none",
        scrollTrigger: {
          trigger: ".pin-section",
          start: "top top",
          end: "bottom bottom",
          scrub: true,
        },
      },
    );
  }
</script>
