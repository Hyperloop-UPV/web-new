---
import i18next, { changeLanguage } from "i18next";
import { changeLanguage, t } from "i18next";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import MissionImageScatter from "../../components/MissionImageScatter.astro";
import SubsystemsAccordion from "../../components/SubsystemsAccordion.astro";
import VehicleTimeline from "../../components/VehicleTimeline.astro";
import PoweredBySupportSection from "../../components/PoweredBySupportSection.astro";
import MeetTeamSection from "../../components/MeetTeamSection.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { contentRepository } from "../../lib/contentful/repository";

changeLanguage("es");

let contentfulLocale = "en-US";
switch (i18next.language) {
    case "es":
        contentfulLocale = "es";
        break;
    case "en":
        contentfulLocale = "en-US";
        break;
    default:
        contentfulLocale = "en-US";
}
const [homePageContent, members] = await Promise.all([
    contentRepository.getHomePageContent(contentfulLocale),
    contentRepository.getMembers(contentfulLocale),
]);
const { hero, missionImages, subsystemItems, vehicleTimeline, partnerLogos } = homePageContent;
const memberFaces = members
    .filter((member): member is typeof member & {
    image: string;
} => Boolean(member.image))
    .map((member) => ({
    image: member.image,
    name: member.name,
    role: member.role,
}));
const shuffled = [...memberFaces];
for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
}
const faceGallery = shuffled.slice(0, Math.min(21, shuffled.length));
---

<Layout
  title={t("site.title")}
  description={hero.description ?? t("site.description")}
  img={hero.bg?.[0]}
>
  <Header slot="header" />
  <Hero bg={hero.bg} description={hero.description} />

  <MissionImageScatter
    title={t("mission.title")}
    description={t("mission.description")}
    images={missionImages}
    imageHeight={300}
    mobileImageHeight={150}
    class="bg-[#0f0f0f]"
  />

  <SubsystemsAccordion items={subsystemItems} />

  <VehicleTimeline items={vehicleTimeline} />

  <PoweredBySupportSection logos={partnerLogos} />

  <MeetTeamSection teamMembers={faceGallery} />

  <SiteFooter />
</Layout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollSmoother } from "gsap/ScrollSmoother";

  gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

  const initHomePage = () => {
    const smoothWrapper = document.getElementById("smooth-wrapper");
    if (!smoothWrapper) return;

    if (smoothWrapper.dataset.homeInit === "true") return;
    smoothWrapper.dataset.homeInit = "true";

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const isMobile = window.innerWidth < 768;

    if (!isMobile && !prefersReducedMotion) {
      (window as any).homeScrollSmoother = ScrollSmoother.create({
        wrapper: "#smooth-wrapper",
        content: "#smooth-content",
        smooth: 1.5,
        effects: true,
        smoothTouch: 0.1,
      });
    }

    if (!prefersReducedMotion) {
      gsap.utils.toArray<HTMLElement>(".fade-up").forEach((el) => {
        gsap.from(el, {
          y: 60,
          opacity: 0,
          duration: 1,
          ease: "power3.out",
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
            toggleActions: "play none none none",
          },
        });
      });
    }

    if (!isMobile && !prefersReducedMotion) {
      const track = document.querySelector<HTMLElement>(".horizontal-track");
      const panels = gsap.utils.toArray<HTMLElement>(".panel");
      if (track && panels.length) {
        gsap.to(track, {
          x: () => -(track.scrollWidth - window.innerWidth),
          ease: "none",
          scrollTrigger: {
            trigger: ".horizontal-scroll-wrapper",
            pin: true,
            scrub: 1,
            end: () => `+=${track.scrollWidth - window.innerWidth}`,
            invalidateOnRefresh: true,
          },
        });
      }
    }

    if (!isMobile && !prefersReducedMotion) {
      const parallaxSection = document.querySelector(".parallax-section");
      const parallaxLayers =
        gsap.utils.toArray<HTMLElement>(".js-parallax-layer");
      if (parallaxSection && parallaxLayers.length) {
        parallaxLayers.forEach((layer) => {
          const depth = Number(layer.dataset.depth ?? 20);
          gsap.fromTo(
            layer,
            { yPercent: -depth * 0.55 },
            {
              yPercent: depth,
              ease: "none",
              scrollTrigger: {
                trigger: parallaxSection,
                start: "top bottom",
                end: "bottom top",
                scrub: true,
                invalidateOnRefresh: true,
              },
            },
          );
        });
      }
    }

    if (!prefersReducedMotion) {
      const teamCopy = document.querySelector(".team-pin-text");
      if (teamCopy) {
        gsap.fromTo(
          teamCopy,
          { y: 24, opacity: 0.4 },
          {
            y: 0,
            opacity: 1,
            ease: "power2.out",
            scrollTrigger: {
              trigger: ".pin-section",
              start: "top 75%",
              end: "top 40%",
              scrub: true,
            },
          },
        );
      }
    }

    if (!isMobile && !prefersReducedMotion) {
      const teamPinColumn = document.querySelector(".team-pin-column");
      const pinSection = document.querySelector(".pin-section");
      if (teamPinColumn && pinSection) {
        ScrollTrigger.create({
          trigger: pinSection,
          start: "top top",
          end: "bottom bottom",
          pin: teamPinColumn,
          pinSpacing: false,
          anticipatePin: 1,
          invalidateOnRefresh: true,
        });
      }
    }

    if (!prefersReducedMotion) {
      const teamGrid = document.querySelector(".team-grid");
      if (teamGrid) {
        const yValue = isMobile ? -60 : -140;
        gsap.fromTo(
          teamGrid,
          { y: 60 },
          {
            y: yValue,
            ease: "none",
            scrollTrigger: {
              trigger: ".pin-section",
              start: "top top",
              end: "bottom bottom",
              scrub: true,
            },
          },
        );
      }
    }

    let resizeTimer: number;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        ScrollTrigger.refresh();
      }, 250);
    });
  };

  document.addEventListener("astro:page-load", initHomePage);
</script>
