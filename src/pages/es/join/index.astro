---
import { changeLanguage, t } from "i18next";
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import PageHero from "../../../components/PageHero.astro";
import FilterBar from "../../../components/FilterBar.astro";
import JobOpeningCard from "../../../components/JobOpeningCard.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import { Building, Workflow, Cpu } from "lucide-astro";
import { contentRepository } from "../../../lib/contentful/repository";

changeLanguage("es");

const pageTitle = String(t("nav.join"));
const pageDescription = String(t("join.description"));
const jobOpenings: any[] = await contentRepository.getJobOpenings("en-US");
// Build subgroup list and grouped openings
const grouped = jobOpenings.reduce((acc: Record<string, any>, job: any) => {
    const subgroupName = job.subgroup?.name ?? t("join.uncategorized");
    if (!acc[subgroupName])
        acc[subgroupName] = { subgroup: job.subgroup, jobs: [] };
    acc[subgroupName].jobs.push(job);
    return acc;
}, {} as Record<string, {
    subgroup: any;
    jobs: any[];
}>);
const subgroups = ["all", ...Object.keys(grouped)];
const subsystems: any[] = await contentRepository.getSubsystemsWithMembers("en-US");
---

<Layout title={pageTitle} description={pageDescription}>
  <Header slot="header" />
  <PageHero
    title={pageTitle}
    description={pageDescription}
    colors={["#0f1829", "#24426d", "#4f86c6"]}
  />

  <section class="py-20 px-6 md:px-10 bg-[#060912] text-white">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12">
        <p class="text-sm uppercase tracking-[0.35em] text-sky-300/80">
          {t("join.team.label")}
        </p>
        <h2 class="mt-2 text-5xl font-black text-white">
          {t("join.team.title")}
        </h2>
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        <div
          class="rounded-2xl border border-white/10 bg-white/5 p-8 flex flex-col items-center text-center"
        >
          <div class="mb-4">
            <Building
              size={48}
              class="mx-auto text-sky-300"
              stroke-width={1.5}
            />
          </div>
          <h3 class="text-xl font-bold text-white">
            {t("join.areas.direction.title")}
          </h3>
          <p class="mt-3 text-sm text-slate-300">
            {t("join.areas.direction.description")}
          </p>
        </div>

        <div
          class="rounded-2xl border border-white/10 bg-white/5 p-8 flex flex-col items-center text-center"
        >
          <div class="mb-4">
            <Workflow
              size={48}
              class="mx-auto text-sky-300"
              stroke-width={1.5}
            />
          </div>
          <h3 class="text-xl font-bold text-white">
            {t("join.areas.operations.title")}
          </h3>
          <p class="mt-3 text-sm text-slate-300">
            {t("join.areas.operations.description")}
          </p>
        </div>

        <div
          class="rounded-2xl border border-white/10 bg-white/5 p-8 flex flex-col items-center text-center"
        >
          <div class="mb-4">
            <Cpu size={48} class="mx-auto text-sky-300" stroke-width={1.5} />
          </div>
          <h3 class="text-xl font-bold text-white">
            {t("join.areas.engineering.title")}
          </h3>
          <p class="mt-3 text-sm text-slate-300">
            {t("join.areas.engineering.description")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-6 md:px-10 bg-[#0a0d14] text-white">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12">
        <p class="text-sm uppercase tracking-[0.35em] text-sky-300/80">
          {t("join.subsystems.label")}
        </p>
        <h2 class="mt-2 text-5xl font-black text-white">
          {t("join.subsystems.title")}
        </h2>
      </div>

      <div class="space-y-4">
        {
          subsystems.map((subsystem) => (
            <details class="group rounded-2xl border border-white/10 bg-white/5 p-6 transition hover:bg-white/8 cursor-pointer">
              <summary class="flex items-start justify-between gap-4 list-none">
                <div>
                  <h3 class="text-2xl font-bold text-white">
                    {subsystem.name}
                  </h3>
                </div>
                {subsystem.icon && (
                  <img
                    src={subsystem.icon}
                    alt={subsystem.name}
                    class="w-12 h-12 shrink-0 opacity-80 group-open:opacity-100"
                  />
                )}
              </summary>
              {subsystem.description && (
                <p class="mt-4 text-base text-slate-300">
                  {subsystem.description}
                </p>
              )}
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-16 px-6 md:px-10 bg-[#0c0f16] text-white">
    <div class="mx-auto max-w-6xl">
      <FilterBar items={subgroups} />

      <div class="space-y-10" id="job-openings">
        {
          Object.entries(grouped).map(([subgroupName, group]) => (
            <section class="group-section" data-subgroup={subgroupName}>
              <div class="mb-6">
                <h2 class="text-3xl font-bold">{subgroupName}</h2>
                {group.subgroup?.description && (
                  <p class="mt-2 text-white/70">{group.subgroup.description}</p>
                )}
              </div>

              <div class="grid gap-6 lg:grid-cols-2">
                {group.jobs.map((job: any) => (
                  <JobOpeningCard jobOpening={job} />
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>

  <SiteFooter />

  <script type="module">
    const buttons = Array.from(document.querySelectorAll("[data-filter]"));
    const sections = Array.from(document.querySelectorAll("[data-subgroup]"));

    const setActive = (selected) => {
      buttons.forEach((btn) => {
        btn.classList.toggle("bg-white/20", btn.dataset.filter === selected);
      });

      sections.forEach((section) => {
        const subgroup = section.getAttribute("data-subgroup");
        section.classList.toggle(
          "hidden",
          selected !== "all" && subgroup !== selected,
        );
      });
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        setActive(button.dataset.filter);
      });
    });

    setActive("all");
  </script>

  <style>
    .filter-button:focus {
      outline: none;
      box-shadow: 0 0 0 3px rgba(100, 177, 255, 0.6);
    }

    .group-section {
      transition: opacity 0.2s ease;
    }
  </style>
</Layout>
