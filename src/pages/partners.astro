---
import { changeLanguage, t } from "i18next";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { contentRepository } from "../lib/contentful/repository";

changeLanguage("en");

const pageTitle = String(t("nav.partners"));
const pageDescription = String(t("partners.body"));
const partners = await contentRepository.getPartners("en-US");
const partnersByTier: Record<string, typeof partners> = {};
for (const partner of partners) {
    const tier = partner.status?.name ?? "Other";
    if (!partnersByTier[tier])
        partnersByTier[tier] = [];
    partnersByTier[tier].push(partner);
}
---

<Layout title={pageTitle} description={pageDescription}>
  <Header slot="header" />
  <PageHero
    title={pageTitle}
    description={pageDescription}
    colors={["#1f1a12", "#6d4a20", "#d38a3e"]}
  />

  <section
    class="left-1/2 -translate-x-1/2 max-w-[1200px] py-20 px-6 md:px-10 bg-[#0f0f0f] text-white relative"
  >
    <h2 class="text-4xl font-black mb-10">{t("partners.by_tier")}</h2>
    <div class="space-y-16">
      {
        Object.entries(partnersByTier).map(([tier, tierPartners]) => (
          <div>
            <h3 class="text-2xl font-bold mb-4 flex items-center gap-3">
              <span>{tier}</span>
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              {tierPartners.map((partner) => (
                <a
                  href={partner.url || "#"}
                  class="partner-card group relative overflow-hidden rounded-2xl border border-white/10 bg-[#181818] p-4 flex flex-col items-center"
                  target="_blank"
                  rel="noopener"
                >
                  {partner.image && (
                    <img
                      src={partner.image}
                      alt={partner.name}
                      class="h-16 w-16 object-contain mb-2"
                    />
                  )}
                  <span class="partner-name font-bold text-lg mb-1">
                    {partner.name}
                  </span>
                  {partner.status?.colorHex && (
                    <span
                      class="partner-tier-badge px-2 py-1 rounded text-xs"
                      style={`background:${partner.status.colorHex}`}
                    >
                      {tier}
                    </span>
                  )}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <SiteFooter />
</Layout>
