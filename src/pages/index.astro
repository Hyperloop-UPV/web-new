	'/img/4.jpg',
	'/img/5.jpg',
	'/img/6.jpg',
	'/img/7.jpg',
	'/img/8.jpg',
	'/img/9.jpg',
];

const subsystemItems = [
	{
		label: 'Direction',
		href: '#',
		icon: '/img/subsystems/icon/DIRECTION.png',
		description: 'Guide the team forward, make decisive team decisions and lead by example.',
		image: '/img/subsystems/direction.png',
		funImage: '/img/subsystems/directionFun.png',
	},
	{
		label: 'Economics',
		href: '#',
		icon: '/img/subsystems/icon/ECONOMICS.png',
		description: 'Builds cost and energy models to optimize capex, operations, and maintenance while preserving safety and performance targets.',
		image: '/img/subsystems/economics.png',
		funImage: '/img/subsystems/economicsFun.png',
	},
	{
		label: 'Electro',
		href: '#',
		icon: '/img/subsystems/icon/ELECTROMAGNETICS.png',
		description: 'Designs and validates levitation, guidance, and linear propulsion magnetic systems, including field control, losses, and thermal behavior.',
		image: '/img/subsystems/electromagnetics.png',
		funImage: '/img/subsystems/electromagneticsFun.png',
	},
	{
		label: 'Firmware',
		href: '#',
		icon: '/img/subsystems/icon/FIRMWARE.png',
		description: 'Implements deterministic embedded control for sensors, motor drives, braking, and fault handling with tight real-time constraints.',
		image: '/img/subsystems/firmware.png',
		funImage: '/img/subsystems/firmwareFun.png',
	},
	{
		label: 'Software',
		href: '#',
		icon: '/img/subsystems/icon/SOFTWARE.png',
		description: 'Develops autonomy, telemetry, diagnostics, and operator tooling that coordinate vehicle state estimation and supervisory control.',
		image: '/img/subsystems/software.png',
		funImage: '/img/subsystems/softwareFun.png',
	},
	{
		label: 'Hardware',
		href: '#',
		icon: '/img/subsystems/icon/HARDWARE.png',
		description: 'Integrates power electronics, sensing, communications, and compute platforms into robust onboard systems qualified for test campaigns.',
		image: '/img/subsystems/hardware.png',
		funImage: '/img/subsystems/hardwareFun.png',
	},
	{
		label: 'Mechanics',
		href: '#',
		icon: '/img/subsystems/icon/MECHANICS.png',
		description: 'Engineers chassis, suspension interfaces, braking components, and manufacturable assemblies to withstand acceleration and vibration loads.',
		image: '/img/subsystems/mechanics.png',
		funImage: '/img/subsystems/mechanicsFun.png',
	},
	{
