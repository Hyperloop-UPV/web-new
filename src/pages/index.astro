const vehicleTimeline = [
	{
		code: 'VÉSPER',
		years: '2023 - 2024',
		vehicleName: 'H9',
		description:
			'Next-generation platform focused on higher stability at speed, modular serviceability, and tighter integration between levitation, guidance, and control software.',
		accolades: ['Vehicle architecture milestone', 'Integrated controls validation', 'Expanded test envelope'],
		image: '/img/timeline/h11.png',
	},
	{
		code: 'KÉNOS & ATLAS',
		years: '2022 - 2023',
		vehicleName: 'H8',
		description:
			'Iteration centered on reliability upgrades, powertrain efficiency, and repeatable dynamic tests under stricter safety and telemetry constraints.',
		accolades: ['Full-stack systems integration', 'Advanced telemetry campaign', 'High-repeatability test runs'],
		image: '/img/timeline/h10.png',
	},
	{
		code: 'AURAN',
		years: '2021 - 2022',
		vehicleName: 'H7',
		description:
			'The first vehicle to achieve dynamic levitation in vacuum conditions, defining a major performance milestone and earning world champion status.',
		accolades: ['Top 1 in European Hyperloop Week'],
		image: '/img/timeline/h9.png',
	},
	{
		code: 'IGNIS',
		years: '2020 - 2021',
		vehicleName: 'H6',
		description:
			'The most complete vehicle of its cycle, combining levitation and vacuum operation to reduce friction and validate end-to-end subsystem coordination.',
